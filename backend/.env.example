# ---- Server ----
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=*

# ---- Database ----
MONGO_URI=mongodb://127.0.0.1:27017/attendance

# ---- Auth ----
JWT_SECRET=change_me_to_a_long_random_value
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# ---- Admin seed (fallback if DB empty) ----
ADMIN_MOBILE=1234567890
ADMIN_PASSWORD=0987654321
ADMIN_EMAIL=admin@example.com

# ---- Cloudinary ----
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_key
CLOUDINARY_API_SECRET=your_secret
CLOUDINARY_FOLDER=attendance

# ---- Email (SMTP) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM="Attendance <no-reply@example.com>"

# ---- Face match ----
FACE_MATCH_THRESHOLD=0.55
